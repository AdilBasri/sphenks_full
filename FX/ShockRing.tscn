[gd_scene load_steps=4 format=3]

[sub_resource type="GDScript" id="GDScript_ring"]
script/source = "extends Node3D
func _ready():
	var tw = create_tween().set_parallel(true)
	tw.tween_property(self, \"scale\", Vector3(1.2, 0.05, 1.2), 0.4).from(Vector3(0.1, 0.05, 0.1)).set_trans(Tween.TRANS_EXPO).set_ease(Tween.EASE_OUT)
	var mesh_inst = get_node_or_null(\"Mesh\")
	if mesh_inst:
		var mat = mesh_inst.mesh.material
		tw.tween_property(mat, \"albedo_color:a\", 0.0, 0.4).from(0.4)
	tw.chain().tween_callback(queue_free)
"

