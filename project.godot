; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sphenks_Full"
run/main_scene="res://Splash.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false

[autoload]

GlobalShaderApplier="*res://Shaders/GlobalShaderApplier.gd"
PieceDatabase="*res://PieceDatabase.gd"
InspectUI="*res://InspectUI.tscn"
SesYoneticisi="*res://SesYoneticisi.gd"
SettingsManager="*res://SettingsManager.gd"
CustomCursor="*res://CustomCursor.tscn"
OnlineManager="*res://OnlineManager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=3
window/size/borderless=true
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Sphenks_Full"

[editor]

version_control/godotsteam=false

[editor_plugins]

enabled=PackedStringArray("res://addons/godotsteam/plugin.cfg")

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/default_filters/use_nearest_mipmap_filter=true

[steam]

initialization/app_id=480
initialization/initialize_on_startup=false
initialization/embed_callbacks=false
multiplayer_peer/max_channels=4
