[sub_resource type="Shader" id="Shader_hypnotic"]
code = "shader_type canvas_item;

void fragment() {
    vec2 uv = UV * 2.0 - 1.0;
    uv.x *= 1.77; // Aspect ratio (640/360)
    
    float t = TIME * 0.4;
    float d = length(uv);
    float angle = atan(uv.y, uv.x);
    
    // Complex, multi-layered hypnotic wave patterns
    float wave1 = sin(d * 12.0 - t * 4.0 + sin(angle * 3.0 + t));
    float wave2 = cos(d * 18.0 + t * 2.0 - cos(angle * 5.0 - t * 0.5));
    float wave3 = sin(uv.x * 10.0 + uv.y * 10.0 + t) * 0.5 + 0.5;
    
    float final_wave = (wave1 + wave2 + wave3) / 3.0;
    
    // Red/Blue palette as requested
    vec3 color_blue = vec3(0.02, 0.05, 0.25); // Deep Mysterious Blue
    vec3 color_red = vec3(0.4, 0.02, 0.08);   // Dark Velvet Red
    
    vec3 col = mix(color_blue, color_red, final_wave * 0.5 + 0.5);
    
    // Noise for texture
    float noise = fract(sin(dot(uv, vec2(12.9898, 78.233))) * 43758.5453);
    col += noise * 0.02;
    
    // Vignette for depth
    col *= smoothstep(1.8, 0.4, d);
    
    COLOR = vec4(col, 1.0);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_root"]
shader = SubResource("Shader_hypnotic")

